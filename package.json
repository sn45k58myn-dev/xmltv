{
  "name": "xmltv-aggregator",
  "version": "3.0.0",
  "description": "XMLTV EPG aggregation service with multiple sources, normalization, deduplication, alias matching and profile exports.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && copyfiles -u 1 \"src/admin/**/*\" dist",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "backup:db": "node scripts/backup-postgres.js",
    "restore:db": "node scripts/restore-postgres.js",
    "backup:verify": "node scripts/verify-backup-postgres.js",
    "backup:prune": "node scripts/prune-backups.js",
    "benchmark:feeds": "node scripts/benchmark-feeds.js",
    "import": "tsx src/cli/import.ts",
    "smoke:import": "tsx src/cli/importSmoke.ts",
    "export": "tsx src/cli/export.ts",
    "metadata:backfill": "tsx src/cli/backfillMetadata.ts",
    "metadata:iptv-org": "tsx src/cli/enrichFromIptvOrg.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build && npm test",
    "admin": "tsx src/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bullmq": "^5.78.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "prisma": "^5.22.0",
    "redis": "^5.12.1",
    "slugify": "^1.6.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.17.0",
    "globals": "^15.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
