{
  "name": "xmltv-aggregator",
  "version": "3.0.0",
  "description": "XMLTV EPG aggregation service with multiple sources, normalization, deduplication, alias matching and profile exports.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && copyfiles -u 1 \"src/admin/**/*\" dist",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "import": "tsx src/cli/import.ts",
    "export": "tsx src/cli/export.ts",
    "lint": "eslint src --ext .ts",
    "admin": "tsx src/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fast-xml-parser": "^4.5.6",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "slugify": "^1.6.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "copyfiles": "^2.4.1",
    "eslint": "^9.17.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
