DATABASE_URL="postgresql://xmltv:${POSTGRES_PASSWORD}@postgres:5432/xmltv?schema=public"
NODE_ENV=production
PORT=3000
BASE_URL=https://xmltv.example.com

SCHEDULES_DIRECT_USERNAME=
SCHEDULES_DIRECT_PASSWORD=
SCHEDULES_DIRECT_COUNTRY=GBR
SCHEDULES_DIRECT_LINEUP=
SCHEDULES_DIRECT_DAYS=7
SCHEDULES_DIRECT_BASE_URL=https://json.schedulesdirect.org/20141201
CUSTOM_XMLTV_URLS=
WEBGRAB_SOURCE_FILES=/app/data/webgrab/guide.xml

ADMIN_TOKEN=replace-with-a-long-random-admin-token
PUBLIC_EXPORTS=false
CORS_ORIGIN=https://xmltv.example.com
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_MB=200
TRUST_PROXY=true

SOURCE_FETCH_TIMEOUT_MS=60000
SOURCE_FETCH_MAX_MB=1024
SOURCE_FETCH_MAX_REDIRECTS=0
SOURCE_FETCH_RETRIES=2
SOURCE_RETRY_DELAY_MS=1000
SOURCE_HEAD_TIMEOUT_MS=10000
SOURCE_FAILURE_BACKOFF_MINUTES=30
IMPORT_TIMEOUT_MS=1800000
SCHEDULER_LOCK_TTL_MS=3600000
IMPORT_RUN_MODE=inline
JOB_QUEUE_BACKEND=database
ENABLE_WORKER=false
WORKER_POLL_MS=5000
WORKER_LOCK_TTL_MS=1800000
WORKER_SHUTDOWN_TIMEOUT_MS=30000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_STORE=memory
REDIS_URL=
MONITORING_TOKEN=replace-with-a-long-random-monitoring-token
TMDB_API_KEY=
PREMIUM_ENABLED=true
PROGRAM_RETENTION_DAYS=14
AUDIT_LOG_RETENTION_DAYS=180
JOB_RUN_RETENTION_DAYS=90
JOB_QUEUE_RETENTION_DAYS=30
FEED_QUALITY_RETENTION_DAYS=180
SOURCE_HEALTH_RETENTION_DAYS=180
FEED_DOWNLOAD_RETENTION_DAYS=365
EXPORT_PAST_HOURS=12
EXPORT_FUTURE_DAYS=7
ENABLE_DEBUG_ROUTES=false
RUN_MIGRATIONS=true
BACKUP_DIR=backups
ENABLE_SCHEDULER=true
FEED_CACHE_MAX_AGE_SECONDS=300
CACHE_WARNING_MB=1024
VALIDATION_MAX_FEED_MB=250
VALIDATION_TIMEOUT_MS=30000
WEBGRAB_ENABLED=true
WEBGRAB_COUNTRIES=
WEBGRAB_AUTO_CONFIG_FILE=
WEBGRAB_REGISTER_SITEINI_SOURCES=true
WEBGRAB_SITEINI_SOURCE_ENABLED=true
WEBGRAB_EXECUTABLE=
WEBGRAB_COMMAND=true
WEBGRAB_WORKDIR=/app/data/webgrab
WEBGRAB_OUTPUT_FILE=guide.xml
WEBGRAB_SOURCE_NAME=WebGrabPlus
WEBGRAB_SOURCE_PRIORITY=90
WEBGRAB_SOURCE_MERGE_WEIGHT=50
WEBGRAB_TIMEOUT_MS=3600000
WEBGRAB_MAX_OUTPUT_MB=1024
WEBGRAB_REBUILD_FEEDS=true
